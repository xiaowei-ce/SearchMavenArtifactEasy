<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- Unique identifier of the plugin. It should be FQN. It cannot be changed between the plugin versions. -->
    <id>cc.xiaowei.SearchMavenArtifactEasy</id>

    <!-- Public plugin name should be written in Title Case.
     Guidelines: https://plugins.jetbrains.com/docs/marketplace/best-practices-for-listing.html#plugin-name -->
    <name>SearchMavenArtifactEasy</name>

    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <vendor url="https://github.com/xiaowei">xiaowei</vendor>

    <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/plugin-content.html#plugin-description -->
    <description><![CDATA[
        <h3>SearchMavenArtifactEasy</h3>
        <p>Search Maven Central dependencies and add them directly to pom.xml.</p>
        <ul>
            <li><strong>Search:</strong> Search Maven artifacts by keyword</li>
            <li><strong>Browse Versions:</strong> View all available versions for any artifact</li>
            <li><strong>XML Preview:</strong> Preview the dependency XML before adding</li>
            <li><strong>Add to pom.xml:</strong> Insert the dependency directly into your pom.xml via PSI</li>
        </ul>
    ]]></description>

    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.platform</depends>
    <version>1.0</version>

    <actions>
        <action id="MavenSearchAction" class="cc.xiaowei.MavenSearchAction"
                text="Search Maven Artifact Easy"
                description="Search and add Maven dependencies from Maven Central">
            <add-to-group group-id="ToolsMenu" anchor="first"/>
            <add-to-group group-id="EditorPopupMenu" anchor="first"/>
        </action>
    </actions>
</idea-plugin>
